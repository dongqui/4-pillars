    "@4-pillars/saju-core": "workspace:*",
    "@4-pillars/report-engine": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "drizzle-kit": "^0.28.1",
    "vitest": "^2.1.8"
  }
